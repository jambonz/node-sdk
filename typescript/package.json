{
  "name": "@jambonz/sdk",
  "version": "0.1.3",
  "description": "jambonz SDK for building voice applications — optimized for AI agents",
  "author": "Dave Horton",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jambonz/node-sdk.git",
    "directory": "typescript"
  },
  "homepage": "https://github.com/jambonz/node-sdk#readme",
  "keywords": [
    "jambonz",
    "voip",
    "telephony",
    "voice",
    "sip",
    "cpaas",
    "sdk",
    "ai-agent"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./webhook": {
      "import": {
        "types": "./dist/webhook/index.d.ts",
        "default": "./dist/webhook/index.js"
      },
      "require": {
        "types": "./dist/webhook/index.d.cts",
        "default": "./dist/webhook/index.cjs"
      }
    },
    "./websocket": {
      "import": {
        "types": "./dist/websocket/index.d.ts",
        "default": "./dist/websocket/index.js"
      },
      "require": {
        "types": "./dist/websocket/index.d.cts",
        "default": "./dist/websocket/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.js"
      },
      "require": {
        "types": "./dist/client/index.d.cts",
        "default": "./dist/client/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/types/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsup && cp -r ../schema ./schema",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "2.1",
    "tsup": "^8.3.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
